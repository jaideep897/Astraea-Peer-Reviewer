# 🔬 ASTRAEA: Environment Configuration Example
# Instructions: Copy this file to '.env' and fill in your credentials.

# --- [CRITICAL] Hugging Face Access ---
# Get your token from: https://huggingface.co/settings/tokens (Needs READ or WRITE access)
HF_TOKEN=your_hugging_face_token_here

# --- [MODEL] AI Engine Configuration ---
# Suggested: meta-llama/Llama-2-70b-chat-hf or gpt-4o-mini
MODEL_NAME=meta-llama/Llama-3.3-70b-instruct
API_BASE_URL=https://api-inference.huggingface.co/models

# --- [SERVER] Deployment Settings ---
PORT=7860
HOST=0.0.0.0
DEBUG_MODE=false
ENABLE_RELOAD=false

# --- [TASK] Default Evaluation ---
# Options: task1, task2, task3, task4, task5, all
TASK_NAME=task1
